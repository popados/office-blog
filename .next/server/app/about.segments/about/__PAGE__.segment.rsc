0:{"rsc":["$","$1","c",{"children":[["$","div",null,{"className":"about-view","children":[["$","div",null,{"className":"page-header","children":[["$","h1",null,{"children":"About the Blog"}],["$","h2",null,{"children":"Hello there! Grab your favorite pen and spiral notebook — let's talk office spaces."}]]}],["$","div",null,{"className":"page-content","children":[["$","div",null,{"className":"about-body","children":[["$","h1",null,{"className":"about-callout-lead","children":"Welcome to the blog — where office supplies are treated less like stationery and more like loot drops for your build."}],["$","p",null,{"children":"Think of this space as a guide for building your ideal workspace loadout. From ergonomic chairs that boost your comfort levels, to desk organizers that help you manage your inventory — everything here is about finding gear that actually improves your daily grind."}],["$","p",null,{"children":"You'll find honest reviews, buying guides, comparisons, and productivity tips — all written from the perspective of someone slowly leveling up their understanding of office gear (and occasionally realizing they didn't need another notebook… but bought it anyway)."}],["$","p",null,{"children":"No pay-to-win recommendations. No endless sales pitches. Just real opinions, tested tools, and a little desk humor for good measure."}],["$","p",null,{"children":"Consider this your starter zone. The quests are simple, the gear is practical, and the final boss is your workday."}],["$","blockquote",null,{"className":"about-quote","children":"Your keyboard is ready. Time to upgrade."}]]}],["$","div",null,{"className":"about-feature-grid","children":[["$","div","Built for Real-World Use, Not Just Stats",{"className":"about-feature","children":[["$","i",null,{"className":"bi bi-tools"}],["$","h3",null,{"children":"Built for Real-World Use, Not Just Stats"}],["$","p",null,{"children":"Every product on this site has been handled, tested, or put through its paces in an actual workspace. No spec-sheet recommendations."}]]}],["$","div","Affiliate Links Clearly Marked",{"className":"about-feature","children":[["$","i",null,{"className":"bi bi-patch-check-fill"}],["$","h3",null,{"children":"Affiliate Links Clearly Marked"}],["$","p",null,{"children":"No stealth loot boxes. If a link earns a commission, you'll know. Transparency is non-negotiable here."}]]}],["$","div","If It's on the List, It Passed Alpha",{"className":"about-feature","children":[["$","i",null,{"className":"bi bi-clipboard2-check-fill"}],["$","h3",null,{"children":"If It's on the List, It Passed Alpha"}],["$","p",null,{"children":"Products earn their spot by passing a real-world test first. If it didn't make the cut in my own setup, it doesn't make the page."}]]}],["$","div","Only Gear from My Own Workspace",{"className":"about-feature","children":[["$","i",null,{"className":"bi bi-shield-check"}],["$","h3",null,{"children":"Only Gear from My Own Workspace"}],["$","p",null,{"children":"This site is built from lived-in experience — not press samples or paid placements. The inventory is personal."}]]}]]}]]}]]}],null,["$","$L2",null,{"children":["$","$3",null,{"name":"Next.MetadataOutlet","children":"$@4"}]}]]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"PUJO8GaUTtNIheOyK4Tek"}
